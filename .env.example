# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nexusflow:password@localhost:5432/nexusflow
AUDIT_DB_URL=sqlite+aiosqlite:///./nexusflow_audit.db

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── IBM Bob (activate July 1) ─────────────────────────────────────────────────
IBM_BOB_API_KEY=
IBM_BOB_BASE_URL=https://api.ibm.com/bob/v1

# ── LLM Routing (OpenRouter covers Llama + Mixtral) ──────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── MCP Tool Adapters ─────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
GITHUB_TOKEN=ghp_
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── NexusFlow Config ─────────────────────────────────────────────────────────
POLICY_FILE_PATH=./policies/default.yaml
DECISION_BUDGET_THRESHOLD=50000
PIPELINE_TIMEOUT_SECONDS=300
